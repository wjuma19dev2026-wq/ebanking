extends ../layout.pug
include movement.pug
include actions.pug


block content
	#wrapper
		include ./current-balance.pug
		main.container.mb-5
			.row
				.col-6
					.card#card-movements.border.border-3
						.card-body.bg-dark
							ul.list-group.list-group-flush#movements
				.col-6
					.row
					+actions({
						color: 'warning', 
						title: 'transfer money',
						cajas: [
							{ type: 'text', name: 'transfer-to', label: 'transferto', id: 'transfer-to', placeholder: 'Transfer to' },
							{ type: 'number', name: 'transfer-amount', label: 'amount', id: 'transfer-amount' }
						],
						icon: 'arrow-right',
						btn: 'btn-transfer'
					})
					+actions({
						color: 'success', 
						title: 'request loan',
						cajas: [
							{ type: 'number', name: 'loan-amount', label: 'amount', id: 'loan-amount', placeholder: 'Your loan amount' }
						],
						icon: 'arrow-right',
						btn: 'btn-loan'
					})
					+actions({
						color: 'danger', 
						title: 'close account',
						cajas: [
							{ type: 'text', name: 'delete-account', label: 'confirm user', id: 'delete-account', placeholder: 'Username' },
							{ type: 'numer', name: 'delete-account-pin', label: 'confirm pin', id: 'delete-account-pin', placeholder: 'Pin' }
						],
						icon: 'arrow-right',
						btn: 'btn-delete',
					})
			.row
				.col-8.mt-5
					.card.border.border-3.text-bg-dark
						.card-body.d-flex.justify-content-between.align-items-center.mx-3
							span
								|	In&nbsp;
								span.text-success.fs-2#label-sum-in 0.000
							span
								| Out&nbsp;
								span.text-danger.fs-2#label-sum-out 0.000
							span
								| Interest&nbsp;
								span.text-success.fs-2.text-decoration-underline#label-sum-int 1.1
							div.d-flex.flex-column.justify-content-center.align-items-center#btn-sorted(style="cursor: pointer;")
								i.bi.bi-arrow-down.d-flex
								|	Sort
				.col-4.mt-5#logged-out-text
					p.fw-lighter.text-muted You will logged out in&nbsp;
					span.fw-bold 5:00

